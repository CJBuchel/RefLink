# Copy to .env and fill in for your deployment. docker-compose.yml reads these automatically.

# IP/hostname of the Cheesy Arena (FMS) server.
FMS_HOST=10.0.100.5
FMS_PORT=8080

# Must be unique per RefLink instance if more than one connects to the same event
# (identifies this client on Cheesy Arena's field_monitor websocket).
FMS_DISPLAY_ID=5333

# Only required if the Cheesy Arena event has an admin password configured.
FMS_ADMIN_PASSWORD=
